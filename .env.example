# Vercel — rollout Payment V2 canary (npm run rollout:payment-v2:local)
# Token compte : https://vercel.com/account/tokens (scope Full Account / bonne team)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=prj_...
# VERCEL_ORG_ID=team_...   # requis si le projet est sous une team Vercel
# https://supabase.com/dashboard/project/hbdnzajbyjakdhuavrvb/settings/api
# API Keys → Publishable key (sb_publishable_...) — les JWT legacy anon (eyJ...) sont désactivés.

VITE_SUPABASE_URL=https://hbdnzajbyjakdhuavrvb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_votre_cle

# Scripts verify:* (local uniquement — ne jamais committer la vraie clé)
# Dashboard > Settings > API > service_role (sb_secret_...)
# Requis pour : npm run verify:payment-v2, audit:security-gates, verify:phase0:signoff
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Read replica (optionnel) — load balancer Supabase (geo-routing GET)
# Apres ajout replica : Dashboard > Infrastructure > Add Read Replica
VITE_SUPABASE_READ_URL=https://hbdnzajbyjakdhuavrvb-all.supabase.co

# Alias accepté par le client (même valeur que ci-dessus)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_votre_cle

# Vérification : npm run verify:supabase-keys
# Doc déploiement : docs/DEPLOIEMENT_FRONT_SUPABASE_KEYS.md

# CI E2E commerce_type (GitHub Actions — npm run setup:commerce-e2e-secret) :
# SUPABASE_TEST_SERVICE_ROLE_KEY=sb_secret_...
# VITE_SUPABASE_TEST_ANON_KEY=sb_publishable_...
# VITE_SUPABASE_TEST_URL=https://<projet-test>.supabase.co   # ≠ prod si possible
#
# Garde-fou E2E (tests destructifs — commerce-gating, vertical-paid) :
# Obligatoire : projet Supabase TEST isolé (ref ≠ prod)
E2E_PRODUCTION_SUPABASE_PROJECT_REF=hbdnzajbyjakdhuavrvb
VITE_SUPABASE_TEST_URL=https://<autre-ref>.supabase.co
SUPABASE_TEST_SERVICE_ROLE_KEY=sb_secret_...
VITE_SUPABASE_TEST_ANON_KEY=sb_publishable_...
# E2E_ALLOW_PRODUCTION_SUPABASE=1   # override dangereux — déconseillé
#
# Vérification garde-fou : npm run test:e2e-guard
# CI : verify-commerce-e2e-secrets.mjs skip si prod sans VITE_SUPABASE_TEST_URL
#
# Purge orphelins E2E en admin prod :
# npm run cleanup:e2e-orphans -- --dry-run
# npm run cleanup:e2e-orphans -- --confirm-production
#
# Local E2E (variables déjà sur Vercel) :
#   npm run env:e2e:pull          # -> .env.e2e.local (gitignored)
#   npm run test:e2e:vertical-paid:local
# Vercel ≠ GitHub Actions : dupliquer les valeurs ou npm run setup:commerce-e2e-secret

# Web Push (générer avec: node scripts/generate-vapid-keys.mjs)
# VITE_VAPID_PUBLIC_KEY=BNx... (clé publique base64url, côté client Vercel)
# Supabase Edge: VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY
# VAPID_SUBJECT=mailto:contact@emarzona.com (optionnel — sujet JWT VAPID)
# npm run setup:vapid-secrets

# Cache enterprise (déploiement: scripts/deploy-cache-enterprise.ps1)
# CACHE_INVALIDATION_SECRET=
# CRON_SECRET=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Orchestration paiements multi-PSP (Stripe Connect, PayPal Commerce, Moneroo)
# VITE_PAYMENT_ORCHESTRATION_V2=true
# Rollout canary prod : npm run prepare:payment-v2-rollout -- --execute
# Checklist : docs/PAYMENT_V2_CANARY_10_CHECKLIST.md
# Rollout canary prod : 10 → 50 → 100 (hash déterministe par storeId)
# VITE_PAYMENT_ORCHESTRATION_V2_ROLLOUT=50
# Actif automatiquement sur previews Vercel si non défini (voir src/lib/payments/feature-flags.ts)

# Debug erreurs UI en production (optionnel, ≥16 caractères) — usage : ?debug_token=<valeur>
# VITE_ERROR_DEBUG_TOKEN=

# RGPD — délai de grâce avant purge auto des comptes (Edge secret, jours 7–90, défaut 30)
# GDPR_DELETION_GRACE_DAYS=30
# Config SQL alternative : platform_settings key=compliance → gdpr_deletion_grace_days
# Cron : SELECT public.setup_account_deletion_cron_job('<project_ref>', '<CRON_SECRET>');
