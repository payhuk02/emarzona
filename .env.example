# Copier vers .env.local ou .env et remplir avec les valeurs du dashboard Supabase
# https://supabase.com/dashboard/project/hbdnzajbyjakdhuavrvb/settings/api
# API Keys → Publishable key (sb_publishable_...) — les JWT legacy anon (eyJ...) sont désactivés.

VITE_SUPABASE_URL=https://hbdnzajbyjakdhuavrvb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_votre_cle

# Alias accepté par le client (même valeur que ci-dessus)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_votre_cle

# Vérification : npm run verify:supabase-keys
# Doc déploiement : docs/DEPLOIEMENT_FRONT_SUPABASE_KEYS.md

# CI E2E commerce_type (GitHub Actions secrets) :
# SUPABASE_TEST_SERVICE_ROLE_KEY=sb_secret_... (full key — NOT CLI masked output with ···)
# Rotate via: npm run setup:commerce-e2e-secret
# VITE_SUPABASE_TEST_URL / VITE_SUPABASE_TEST_ANON_KEY (optionnel ; fallback sur VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_KEY)

# Web Push (générer avec: node scripts/generate-vapid-keys.mjs)
# VITE_VAPID_PUBLIC_KEY=BNx... (clé publique base64url, côté client Vercel)
# Supabase Edge: VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY

# Cache enterprise (déploiement: scripts/deploy-cache-enterprise.ps1)
# CACHE_INVALIDATION_SECRET=
# CRON_SECRET=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Orchestration paiements multi-PSP (Stripe Connect, PayPal Commerce, Moneroo)
# VITE_PAYMENT_ORCHESTRATION_V2=true
# Rollout canary prod : 10 → 50 → 100 (hash déterministe par storeId)
# VITE_PAYMENT_ORCHESTRATION_V2_ROLLOUT=50
# Actif automatiquement sur previews Vercel si non défini (voir src/lib/payments/feature-flags.ts)
