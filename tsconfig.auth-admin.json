{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noCheck": false,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/vite-env.d.ts",
    "src/contexts/AuthContext.tsx",
    "src/components/AdminRoute.tsx",
    "src/hooks/useAdmin.ts",
    "src/integrations/supabase/client.ts"
  ],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.*", "src/**/*.spec.*", "src/test/**"]
}
