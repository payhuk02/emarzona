{
  "name": "emarzona",
  "private": true,
  "version": "1.0.0",
  "description": "Plateforme de ecommerce et marketing - Application SaaS E-commerce de produits digitaux, physiques, services, cours en ligne et oeuvres d'artiste",
  "author": "Emarzona Team",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "build:dev": "vite build --mode development",
    "typecheck:critical": "tsc -p tsconfig.critical.json --noEmit",
    "typecheck:auth-admin": "tsc -p tsconfig.auth-admin.json --noEmit",
    "typecheck:commerce-core": "tsc -p tsconfig.commerce-core.json --noEmit",
    "typecheck:marketplace-core": "tsc -p tsconfig.marketplace-core.json --noEmit",
    "typecheck:ops-core": "tsc -p tsconfig.ops-core.json --noEmit",
    "lint": "eslint .",
    "lint:ci": "npm run lint:ci:critical",
    "lint:ci:phase1": "eslint . --max-warnings=300",
    "lint:ci:phase2": "eslint . --max-warnings=100",
    "lint:ci:phase3": "eslint . --max-warnings=0",
    "lint:ci:critical": "eslint src/components/pixels/PixelInjector.tsx src/components/storefront/StoreAnalyticsScripts.tsx src/integrations/payments/*.ts src/integrations/supabase/client.ts src/lib/webhooks/*.ts src/lib/logger.ts src/lib/sendgrid.ts src/services/fedex/*.ts src/types/webhooks.ts --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:payments": "vitest run src/lib/payments",
    "test:unit:stable": "vitest run --maxWorkers=2",
    "test:guards": "vitest run src/components/billing/__tests__/SellerRoutePermissionGuard.test.tsx src/lib/billing/__tests__/physical-route-capabilities.test.ts src/lib/admin/__tests__/admin-route-permissions.test.ts",
    "test:navigation": "vitest run src/config/__tests__/sidebar-routes.test.ts src/config/__tests__/navigation-phase4.test.ts src/config/__tests__/navigation-context.test.ts src/config/__tests__/navigation-context-phase6.test.ts src/config/__tests__/layoutTypeDetection.test.ts src/hooks/__tests__/useNavigationAnalytics.test.ts src/lib/navigation/__tests__/feature-flags.test.ts src/lib/navigation/__tests__/resolveNavItems.test.ts src/lib/navigation/__tests__/resolveHorizontalNav.test.ts src/config/__tests__/sidebar-gap-audit.test.ts src/lib/navigation/__tests__/commerce-sidebar.integration.test.ts",
    "test:commerce-gating": "vitest run src/lib/commerce/__tests__/store-capability-map.test.ts src/components/billing/__tests__/SellerRoutePermissionGuard.test.tsx src/lib/navigation/__tests__/resolveNavItems.test.ts src/lib/navigation/__tests__/commerce-sidebar.integration.test.ts src/lib/navigation/__tests__/horizontal-nav-commerce-gating.test.ts",
    "test:production-truth": "vitest run src/lib/shipping/__tests__/fedex-policy.test.ts src/lib/__tests__/fedex-rates-client.test.ts src/lib/payments/__tests__/feature-flags.test.ts src/lib/cart/__tests__/service-cart-policy.test.ts src/lib/checkout/__tests__/cart-validation.test.ts src/lib/orders/__tests__/resolve-order-number.test.ts src/lib/__tests__/checkout-order-items.test.ts",
    "verify:payment-v2": "node scripts/verify-payment-v2-remote.mjs",
    "verify:fedex-prod": "node scripts/verify-fedex-prod.mjs",
    "rollout:payment-v2:canary": "node scripts/payment-v2-canary.mjs --verify-only",
    "rollout:payment-v2:10": "node scripts/payment-v2-canary.mjs --rollout 10 --dispatch",
    "test:components": "vitest run src/components --maxWorkers=2",
    "test:security": "npm run test:guards && npm run test:unit:payments",
    "audit:rls": "node scripts/audit-rls-check.mjs",
    "audit:security-gates": "npm run audit:rls && npm run audit:storage-public",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --config vitest.ci.config.ts",
    "test:coverage:check": "vitest run --coverage --reporter=verbose && node scripts/check-coverage.js",
    "test:coverage:html": "vitest run --coverage && open coverage/index.html",
    "test:e2e": "playwright test --grep-invert \"visual-regression|accessibility|responsive\"",
    "test:e2e:ci": "playwright test --config=playwright.ci.config.ts",
    "test:e2e:commerce-gating": "playwright test --config=playwright.commerce-gating.config.ts",
    "test:e2e:routes-smoke": "playwright test --config=playwright.routes-smoke.config.ts",
    "test:e2e:vertical-paid": "playwright test --config=playwright.vertical-paid.config.ts",
    "env:e2e:pull": "powershell -NoProfile -File scripts/pull-e2e-env-from-vercel.ps1",
    "test:e2e:vertical-paid:local": "node scripts/run-e2e-with-vercel-env.mjs vertical-paid",
    "test:e2e:commerce-gating:local": "node scripts/run-e2e-with-vercel-env.mjs commerce-gating",
    "test:e2e:auth": "playwright test --config=playwright.auth.config.ts",
    "test:e2e:marketplace": "playwright test tests/e2e/marketplace",
    "test:e2e:products": "playwright test --config=playwright.products.config.ts",
    "test:e2e:cart": "playwright test cart-checkout-workflow",
    "test:e2e:checkout": "playwright test --config=playwright.checkout.config.ts tests/e2e/cart-checkout-workflow.spec.ts tests/e2e/checkout-multi-psp.spec.ts tests/e2e/paypal-commerce-flow.spec.ts",
    "test:e2e:c1-commission": "playwright test tests/e2e/physical-zero-commission-c1.spec.ts --project=chromium",
    "test:e2e:c5-subscription": "playwright test tests/e2e/physical-subscription-activation-c5.spec.ts --project=chromium",
    "test:e2e:financial": "playwright test tests/e2e/partial-refund.spec.ts tests/e2e/physical-zero-commission-c1.spec.ts tests/e2e/physical-subscription-renewal.spec.ts tests/e2e/referral-c1.spec.ts tests/e2e/mixed-cart-service-product.spec.ts tests/e2e/payment-v2-rollout.spec.ts --project=chromium",
    "test:e2e:email": "playwright test email-unsubscribe email-campaign-test-send --project=chromium",
    "verify:supabase-keys": "node scripts/verify-supabase-publishable-key.mjs",
    "setup:commerce-e2e-secret": "node scripts/setup-commerce-e2e-github-secret.mjs",
    "cleanup:e2e-orphans": "node scripts/cleanup-e2e-orphans.mjs",
    "test:visual": "playwright test visual-regression",
    "test:a11y": "playwright test accessibility",
    "test:a11y:check": "node scripts/check-accessibility.js",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:visual && npm run test:a11y",
    "vercel-build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "sitemap:generate": "tsx scripts/generate-sitemap-dynamic.ts",
    "sitemap:generate:old": "node scripts/generate-sitemap.js",
    "build:with-sitemap": "npm run sitemap:generate && vite build",
    "images:setup": "node scripts/setup-image-optimization.js",
    "images:optimize": "tsx scripts/optimize-existing-images.ts",
    "images:check": "node scripts/check-ai-settings-migration.js",
    "test:responsive": "playwright test --project=chromium --project=\"Mobile Chrome\" --project=\"Tablet Chrome\"",
    "test:responsive:all": "playwright test",
    "test:responsive:mobile": "playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:responsive:desktop": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:responsive:visual": "playwright test --grep \"Régression visuelle\"",
    "audit:responsive": "node scripts/responsivity-audit.js",
    "audit:lighthouse": "node scripts/lighthouse-web-vitals.js",
    "audit:lighthouse:a11y": "node scripts/lighthouse-a11y-layouts.mjs",
    "audit:lighthouse:legacy": "node scripts/lighthouse-test.js",
    "measure:vitals": "node scripts/measure-web-vitals.js",
    "audit:all": "npm run audit:responsive && npm run audit:lighthouse",
    "optimize:images": "node scripts/optimize-images-enhanced.js",
    "optimize:images:webp": "node scripts/optimize-images-enhanced.js --format=webp",
    "optimize:images:avif": "node scripts/optimize-images-enhanced.js --format=avif",
    "analyze:bundle:build": "node scripts/analyze-bundle-enhanced.js --build",
    "verify:rls": "node scripts/audit-rls-check.mjs",
    "prepare:rls": "node scripts/execute-rls-migrations-auto.js",
    "prepare:rls:pattern4": "node scripts/execute-rls-migrations-auto.js pattern4",
    "prepare:rls:pattern1": "node scripts/execute-rls-migrations-auto.js pattern1",
    "prepare:rls:pattern2": "node scripts/execute-rls-migrations-auto.js pattern2",
    "prepare:rls:pattern3": "node scripts/execute-rls-migrations-auto.js pattern3",
    "verify:features": "node scripts/verify-features.js",
    "report:csv": "node scripts/generate-csv-report.js",
    "report:playwright": "node scripts/generate-playwright-tests.js",
    "report:all": "npm run report:csv && npm run report:playwright",
    "dev:responsive": "npm run dev & npm run test:responsive:mobile",
    "build:responsive": "npm run build && npm run test:responsive",
    "verify:responsive": "node scripts/verify-product-display.js",
    "verify:all": "npm run verify:responsive && npm run audit:responsive",
    "verify:routes": "tsx scripts/verify-routes.ts",
    "analyze:bundle": "npm run build:analyze && node scripts/analyze-bundle-performance.js",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:shell-imports": "node scripts/check-shell-heavy-imports.mjs",
    "build:check": "npm run check:shell-imports && npm run build && npm run check:bundle-budget",
    "monitor:bundle": "npm run build:check",
    "monitor:bundle:quick": "node scripts/check-bundle-budget.mjs",
    "analyze:bundle:quick": "node scripts/check-bundle-budget.mjs",
    "audit:storage-public": "node scripts/audit-storage-public.mjs",
    "setup:husky": "node scripts/setup-husky.js",
    "prepare": "husky install || true",
    "build:analyze": "npm run build -- --mode analyze",
    "issues:create": "powershell -ExecutionPolicy Bypass -File scripts/create-github-issues.ps1",
    "issues:create:bash": "bash scripts/create-github-issues.sh",
    "issues:create:api": "powershell -ExecutionPolicy Bypass -File scripts/create-github-issues-api.ps1",
    "supabase:types": "npx supabase gen types typescript --project-id hbdnzajbyjakdhuavrvb --schema public > src/integrations/supabase/types.ts",
    "supabase:types:check": "npx supabase gen types typescript --project-id hbdnzajbyjakdhuavrvb --schema public",
    "icons:generate": "node scripts/generate-platform-icons.mjs",
    "audit:aria": "node scripts/audit-aria-labels.js",
    "audit:console": "node scripts/audit-console-logs.js",
    "generate:rls-migration": "node scripts/generate-rls-migrations.js",
    "generate:rls-migrations-batch": "node scripts/generate-rls-migrations-batch.js",
    "list:rls-migrations": "node scripts/list-rls-migrations.js",
    "prepare:rls-execution": "node scripts/prepare-rls-execution.js",
    "verify:before-execution": "node scripts/verify-before-execution.js",
    "execute:rls-migrations": "node scripts/execute-rls-migrations.js",
    "verify:unsubscribe-css": "node scripts/verify-unsubscribe-css.js",
    "loyalty:integrate": "node scripts/integrate-loyalty-events.js",
    "load:test:marketplace": "k6 run scripts/k6/marketplace-rpc.js",
    "deploy:cache": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cache-enterprise.ps1 -Interactive",
    "deploy:cache:ci": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cache-enterprise.ps1",
    "generate:vapid-keys": "node scripts/generate-vapid-keys.mjs"
  },
  "vercel": {
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite"
  },
